service cloud.firestore {
  match /databases/{database}/documents {
    match /products/{productId} {
      // Allow updates only if the user is logged in and is the owner
      allow update: if request.auth != null 
      // Allow reads and creates as needed
      allow read: if true;
      allow create: if request.auth != null;
    }
  }
   match /databases/{database}/documents {
    match /orders/{orderId} {
      // Allow read/write if the user is not null
      allow read, write: if request.auth != null;
    }
  }
   match /databases/{database}/documents {
    match /{document=**} {
      // Allows any authenticated user to read/write. 
      // Narrow this down to specific collections for production.
      allow read, write: if request.auth != null;
    }
  }
}